@model giao_dien_demo.Models.Leave

@{
    ViewData["Title"] = "📝 Tạo đơn nghỉ phép";
}

<style>
    body { background-color: #f5f7fa; }

    /* 1. Tạo khung giấy A4 */
    .a4-paper {
        max-width: 800px;
        margin: 20px auto 50px auto;
        padding: 60px 80px;
        background: #fff;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        font-family: 'Times New Roman', Times, serif; /* Font chuẩn văn bản hành chính */
        font-size: 18px;
        line-height: 1.8;
        color: #000;
        border-radius: 4px;
        animation: fadeIn 0.5s ease;
    }

    /* 2. Biến ô Input thành dòng kẻ chấm chấm để điền */
    .input-word {
        border: none;
        border-bottom: 2px dotted #555;
        outline: none;
        background: transparent;
        font-family: inherit;
        font-size: inherit;
        font-weight: bold;
        color: #000080; /* Màu mực xanh đen giống bút bi */
        padding: 0 10px;
        text-align: center;
    }

    .input-word:focus {
        border-bottom: 2px solid #3498db;
        background-color: #f0f8ff;
    }

    .input-textarea {
        width: 100%;
        border: none;
        border-bottom: 2px dotted #555;
        outline: none;
        font-family: inherit;
        font-size: inherit;
        color: #000080;
        resize: vertical;
        line-height: 1.8;
        background: transparent;
    }
    
    .input-textarea:focus {
        border-bottom: 2px solid #3498db;
        background-color: #f0f8ff;
    }

    /* 3. Nút bấm kỹ thuật số (tách biệt khỏi giao diện giấy) */
    .action-panel {
        max-width: 800px;
        margin: 30px auto 0 auto;
        display: flex;
        justify-content: flex-start;
        font-family: Arial, sans-serif; /* Trả lại font hiện đại cho nút bấm */
    }

    .btn-submit {
        background: linear-gradient(45deg, #00c6ff, #0072ff);
        color: white;
        border: none;
        padding: 12px 40px;
        border-radius: 8px;
        font-weight: bold;
        font-size: 16px;
        transition: 0.3s;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,114,255,0.4);
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="container mt-2">
    <div class="action-panel">
        <a asp-controller="NhanVien" asp-action="Index" class="btn btn-outline-secondary fw-bold shadow-sm">
            ⬅ Quay lại Dashboard
        </a>
    </div>

    <div class="a4-paper">
        <div class="text-center mb-5">
            <h5 class="fw-bold mb-1" style="font-size: 20px;">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h5>
            <h6 class="fw-bold" style="text-decoration: underline; font-size: 18px;">Độc lập - Tự do - Hạnh phúc</h6>
            <br>
            <h2 class="fw-bold mt-3 mb-4" style="font-size: 28px;">ĐƠN XIN NGHỈ PHÉP</h2>
        </div>

        <form asp-action="Create" method="post">
            
            <div class="mb-4">
                <span class="fst-italic">Kính gửi:</span> <strong>Ban Giám đốc & Phòng Hành chính Nhân sự</strong>
            </div>

            <div class="mb-3 d-flex align-items-center">
                <span class="text-nowrap">Tôi tên là: </span>
                <input type="text" name="EmployeeName" class="input-word flex-grow-1 ms-2" required placeholder="Nhập họ và tên..." />
            </div>

            <div class="mb-3 d-flex flex-wrap align-items-center">
                <span class="text-nowrap mt-2">Nay tôi làm đơn này xin phép được nghỉ từ ngày</span>
                <input type="date" name="FromDate" class="input-word mx-2 mt-2" required />
                <span class="text-nowrap mt-2">đến hết ngày</span>
                <input type="date" name="ToDate" class="input-word ms-2 mt-2" required />.
            </div>

            <div class="mb-4 mt-4">
                <span class="d-block mb-1">Lý do xin nghỉ:</span>
                <textarea name="Reason" class="input-textarea" rows="2" required placeholder="Ghi rõ lý do (Ví dụ: Nghỉ ốm, việc gia đình...)"></textarea>
            </div>

            <div class="mb-5" style="text-align: justify;">
                Tôi xin cam đoan sẽ bàn giao công việc đầy đủ cho người có liên quan và đi làm lại đúng thời gian quy định. Kính mong Ban Giám đốc xem xét và chấp thuận.
            </div>

            <div class="mb-3">
                <span class="fst-italic">Xin trân trọng cảm ơn!</span>
            </div>

            <div class="row mt-5">
                <div class="col-6">
                    </div>
                <div class="col-6 text-center">
                    <i style="font-size: 16px;">Ngày ..... tháng ..... năm 202...</i><br>
                    <strong style="font-size: 18px;">Người làm đơn</strong><br>
                    <small class="fst-italic text-muted">(Ký và ghi rõ họ tên)</small><br><br><br><br><br>
                </div>
            </div>

            <div class="text-center mt-4" style="font-family: Arial, sans-serif;">
                <hr class="mb-4" style="border-top: 1px dashed #ccc;">
                <button type="submit" class="btn-submit">
                    🚀 Gửi đơn ngay
                </button>
            </div>

        </form>
    </div>
</div>