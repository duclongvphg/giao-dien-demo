@{
    ViewData["Title"] = "Dashboard";
}

<style>
    body {
        background: #ffffff;
        min-height: 100vh;
        margin: 0;
        font-family: Arial, sans-serif;
    }

    .dashboard-container {
        display: flex;
        padding: 30px;
        background: #ffffff;
        min-height: 100vh;
    }

    .sidebar {
        width: 250px;
        background: #2c3e50;
        border-radius: 15px;
        padding: 20px;
        color: white;
        animation: slideIn 0.5s ease;
    }

        .sidebar h2 {
            text-align: center;
            margin-bottom: 20px;
        }

    .menu a {
        display: block;
        padding: 12px;
        margin: 10px 0;
        border-radius: 10px;
        text-decoration: none;
        color: white;
        transition: 0.3s;
    }

        .menu a:hover {
            background: #3498db;
            transform: translateX(5px);
        }

    .main {
        flex: 1;
        margin-left: 30px;
        color: #333;
        background: #ffffff;
    }

    .cards {
        display: flex;
        gap: 20px;
        margin-top: 20px;
        flex-wrap: wrap;
    }

    .card-link {
        flex: 1;
        min-width: 250px;
        text-decoration: none;
        color: white;
    }

    .card {
        padding: 25px;
        border-radius: 15px;
        color: white;
        font-size: 22px;
        font-weight: bold;
        transition: 0.3s;
        cursor: pointer;
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
        min-height: 120px;
    }

        .card:hover {
            transform: translateY(-10px) scale(1.03);
        }

    .number {
        font-size: 36px;
        margin-top: 20px;
    }

    .blue {
        background: linear-gradient(45deg, #36d1dc, #5b86e5);
    }

    .green {
        background: linear-gradient(45deg, #56ab2f, #a8e063);
    }

    .red {
        background: linear-gradient(45deg, #ff416c, #ff4b2b);
    }

    @@keyframes slideIn {
        from {
            transform: translateX(-50px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
</style>

<div class="dashboard-container">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h2>🚀 HRMS</h2>

        <div class="menu">
            <a asp-controller="Dashboard" asp-action="Index">🏠 Trang chủ</a>
            <a asp-controller="Employee" asp-action="Index">👨‍💼 Nhân viên</a>
            <a asp-controller="Attendance" asp-action="Index">⏱️ Chấm công</a>
            <a asp-controller="Salary" asp-action="Index">💰 Lương</a>
            <a asp-controller="Leave" asp-action="Index">📄 Nghỉ phép</a>
            <a asp-controller="Account" asp-action="Logout">🚪 Đăng xuất</a>
        </div>
    </div>

    <!-- MAIN -->
    <div class="main">
        <h2>📊 Trang chủ hệ thống</h2>

        <div class="cards">

            <a class="card-link"
                   asp-controller="Dashboard"
                   asp-action="EmployeeList"
                   asp-route-status="all">
                <div class="card blue">
                    👨‍💼 Tổng nhân viên
                    <div class="number">@ViewBag.Total</div>
                </div>
            </a>

            <a class="card-link"
                   asp-controller="Dashboard"
                   asp-action="EmployeeList"
                   asp-route-status="working">
                <div class="card green">
                    ✅ Đang làm
                    <div class="number">@ViewBag.Working</div>
                </div>
            </a>

            <a class="card-link"
                   asp-controller="Dashboard"
                   asp-action="EmployeeList"
                   asp-route-status="quit">
                <div class="card red">
                    ❌ Nghỉ việc
                    <div class="number">@ViewBag.Leave</div>
                </div>
            </a>

        </div>
    </div>

</div>