@{
    Layout = null; // Để không hiện Menu khi đang ở trang quên mật khẩu
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu - HRMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
            background-color: #1a202c;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .forgot-container {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 420px;
            animation: slideUp 0.5s ease-out;
        }
        .btn-primary {
            background-color: #4A90E2;
            border: none;
            padding: 12px;
            font-weight: bold;
            transition: 0.3s;
        }
        .btn-primary:hover {
            background-color: #357ABD;
            transform: translateY(-2px);
        }
        .form-control {
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 15px;
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>
    <div class="forgot-container text-center">
        <h3 class="fw-bold mb-2" style="color: #4A90E2;">🚀 HRMS</h3>
        <h5 class="mb-3 text-secondary">Khôi phục mật khẩu</h5>
        <p class="small text-muted mb-4">Vui lòng cung cấp chính xác Tên đăng nhập và Email để hệ thống gửi mã xác nhận.</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger small py-2">⚠️ @ViewBag.Error</div>
        }

        <form asp-action="ForgotPassword" method="post">
            <div class="mb-3">
                @* 🔥 THÊM MỚI: Nhập Tên đăng nhập để định danh tài khoản *@
                <input type="text" name="username" class="form-control" placeholder="Tên đăng nhập của bạn" required />
                
                @* Nhập Email đăng ký *@
                <input type="email" name="email" class="form-control" placeholder="Email đăng ký (Gmail)" required />
            </div>
            
            <button type="submit" class="btn btn-primary w-100 mb-3">Gửi mã xác nhận</button>
            
            <div class="text-center pt-2">
                <a asp-action="Login" class="text-decoration-none small text-primary fw-bold">
                    ← Quay lại Đăng nhập
                </a>
            </div>
        </form>
    </div>
</body>
</html>