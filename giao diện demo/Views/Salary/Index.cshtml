@model List<giao_dien_demo.Models.Salary>
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Bảng lương chi tiết";
    // 🔥 Lấy quyền của User để hiển thị tiêu đề cho phù hợp
    var role = Context.Session.GetString("Role"); 
}

<style>
    /* Style chuyên nghiệp cho bảng lương */
    .table-salary thead th { vertical-align: middle; text-align: center; border-bottom: 2px solid #dee2e6; }
    .group-income { background-color: #e0f2fe !important; color: #0369a1; } /* Nhóm Thu nhập - Xanh dương */
    .group-deduction { background-color: #ffedd5 !important; color: #9a3412; } /* Nhóm Giảm trừ - Cam */
    .text-net-pay { font-weight: bold; color: #16a34a; font-size: 1.1rem; background-color: #f0fdf4; } /* Lương Net - Xanh lá */
    .badge-tax { cursor: help; color: #3b82f6; margin-left: 5px; }
    
    /* Hiệu ứng khi di chuột */
    .table-salary tbody tr:hover { background-color: #f8fafc; transition: 0.2s; }
    .btn-back { text-decoration: none; color: #64748b; font-weight: 500; }
    .btn-back:hover { color: #1e293b; }
</style>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">💰 @(role == "HR" || role == "Admin" || role == "Leader" ? "Bảng lương toàn công ty" : "Lịch sử lương của tôi")</h2>
            <a href="javascript:history.back()" class="btn-back">⬅ Quay về trang chủ</a>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered mb-0 table-salary">
                    <thead>
                        <tr>
                            <th rowspan="2" style="min-width: 200px;">Thông tin nhân viên</th>
                            <th colspan="4" class="group-income">Thu nhập (Gross)</th>
                            <th colspan="3" class="group-deduction">Giảm trừ & Thuế (Deductions)</th>
                            <th rowspan="2" class="text-net-pay">Thực nhận (Net)</th>
                            <th rowspan="2">Thao tác</th>
                        </tr>
                        <tr>
                            <th class="group-income">Lương CB</th>
                            <th class="group-income">Giờ làm</th>
                            <th class="group-income">Thưởng & Phụ cấp</th>
                            <th class="group-income">Tổng thu nhập</th>
                            
                            <th class="group-deduction">Bảo hiểm (10.5%)</th>
                            <th class="group-deduction">Thuế TNCN (5 bậc)</th>
                            <th class="group-deduction">Khác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model) {
                            <tr>
                                <td>
                                    <div class="fw-bold">@item.EmployeeName</div>
                                    <small class="text-muted">Mã: #@item.Id</small>
                                </td>
                                <td class="text-end">@item.BasicSalary.ToString("N0")</td>
                                
                                <td class="text-end">@item.HoursWorked.ToString("0.####") giờ</td>
                                
                                <td class="text-end text-success fw-bold">
                                    +@((item.BonusAndAllowance + item.HolidayBonus + item.DiligenceBonus + item.Reward).ToString("N0"))
                                </td>
                                
                                <td class="text-end fw-bold">@item.TotalSalary.ToString("N0")</td>
                                
                                <td class="text-end text-danger">
                                    -@item.Insurance.ToString("N0") 
                                </td>
                                <td class="text-end">
                                    <span class="text-danger">-@item.TaxTNCN.ToString("N0")</span>
                                    <i class="bi bi-info-circle badge-tax" title="Tính theo biểu thuế lũy tiến 5 bậc."></i>
                                </td>
                                <td class="text-end text-danger">-@item.Discipline.ToString("N0")</td>
                                
                                <td class="text-end text-net-pay">@item.NetSalary.ToString("N0")</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-primary" onclick="window.print()">
                                        <i class="bi bi-printer"></i> In phiếu
                                    </button>
                                </td>
                            </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="10" class="text-center py-4 text-muted">
                                    Chưa có dữ liệu bảng lương.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Khởi tạo Tooltip cho các icon thông tin thuế
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[title]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}