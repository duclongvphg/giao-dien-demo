@{
    ViewData["Title"] = "👨‍💼 Nhân sự (Human Resources)";
    var currentUser = Context.Session.GetString("User");
}

<style>
    /* 1. Căn giữa nội dung bảng */
    .table th, .table td { text-align: center !important; vertical-align: middle !important; }

    /* 2. Toast System */
    #toast-container { position: fixed; top: 20px; right: 20px; z-index: 10000; }
    .custom-toast {
        min-width: 280px; padding: 15px 20px; border-radius: 12px; color: white;
        font-weight: bold; margin-bottom: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        display: none; animation: slideIn 0.5s forwards; border-left: 5px solid rgba(255,255,255,0.5);
    }
    .toast-success { background: linear-gradient(45deg, #2ecc71, #27ae60); }
    .toast-info { background: linear-gradient(45deg, #3498db, #2980b9); }

    @@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

    /* 3. Dashboard Cards */
    .dashboard-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin-top: 20px; }
    .card { padding: 20px; border-radius: 15px; color: white; font-weight: bold; text-align: center; transition: transform 0.2s; border: none; cursor: default; }
    .card:hover { transform: translateY(-5px); }
    .card .number { font-size: 32px; display: block; margin-top: 10px; transition: all 0.5s; }
    
    .blue { background: #4facfe; } .green { background: #43e97b; } .red { background: #f093fb; }
    .orange { background: #f6d365; } .purple { background: #667eea; } .teal { background: #13547a; }

    /* Hiệu ứng yêu cầu mới */
    .new-request { background-color: #fff3cd !important; border-left: 5px solid #ffc107 !important; }
    .sender-tag { font-size: 10px; padding: 2px 6px; border-radius: 5px; background: #34495e; color: white; text-transform: uppercase; }
</style>

<div id="toast-container"></div>

<div class="dashboard-cards">
    <div class="card blue">👥 Nhân viên <div class="number" id="employeeCount">@(ViewBag.TotalEmployees ?? 0)</div></div>
    <div class="card green">⏱ Chấm công <div class="number" id="attendanceCount">@(ViewBag.AttendanceCount ?? 0)</div></div>
    <div class="card red">💰 Lương <div class="number" id="salaryCount">@(ViewBag.SalaryCount ?? 0)</div></div>
    <div class="card orange">📄 Nghỉ phép <div class="number" id="leaveCount">@(ViewBag.LeaveCount ?? 0)</div></div>
    <div class="card purple">📑 Hợp đồng <div class="number" id="contractCount">@(ViewBag.ContractCount ?? 0)</div></div>
    <div class="card teal">📊 Báo cáo <div class="number" id="reportCount">@(ViewBag.ReportCount ?? 0)</div></div>
</div>

<div id="thongbao" style="margin-top:40px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>🔔 Nhật ký hoạt động & Tin nhắn từ các Actor</h3>
        <span class="badge bg-light text-dark border" id="liveStatus">Đang kết nối...</span>
    </div>
    
    <table class="table table-bordered table-hover shadow-sm bg-white">
        <thead class="table-dark">
            <tr>
                <th style="width: 150px;">Thời gian</th>
                <th>Nội dung sự kiện / Tin nhắn</th>
                <th style="width: 250px;">Phân loại</th>
            </tr>
        </thead>
        <tbody id="notificationBody">
            @if (ViewBag.PendingNotifications != null) {
                foreach (var item in ViewBag.PendingNotifications) {
                    <tr class="new-request">
                        <td>@DateTime.Now.ToString("dd/MM HH:mm")</td>
                        <td class="text-start"><strong>@item.Content</strong></td>
                        <td><span class="badge bg-danger">CẦN XỬ LÝ</span></td>
                    </tr>
                }
            }
            <tr>
                <td>@DateTime.Now.ToString("HH:mm:ss")</td>
                <td class="text-start"><span class="text-success">●</span> Hệ thống quản trị HRMS trực tuyến</td>
                <td><span class="text-muted">Hệ thống</span></td>
            </tr>
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/dashboardHub")
            .withAutomaticReconnect()
            .build();

        function showToast(message, type = 'success') {
            const toastId = 'toast-' + Date.now();
            const html = `<div id="${toastId}" class="custom-toast ${type === 'success' ? 'toast-success' : 'toast-info'}">
                            ${message}
                          </div>`;
            $('#toast-container').append(html);
            $(`#${toastId}`).fadeIn();
            setTimeout(() => { $(`#${toastId}`).fadeOut(() => $(`#${toastId}`).remove()); }, 4000);
        }

        function addRow(time, content, tag, isUrgent = false) {
            const rowClass = isUrgent ? 'class="new-request"' : '';
            const html = `<tr ${rowClass}>
                            <td>${time}</td>
                            <td class="text-start">${content}</td>
                            <td><span class="badge bg-primary">${tag}</span></td>
                          </tr>`;
            $("#notificationBody").prepend(html);
        }

        // --- LẮNG NGHE REAL-TIME ---

        // 1. Cập nhật số lượng nhân viên (Phát từ ContractController/Approve)
        connection.on("UpdateEmployeeCount", (count) => {
            const el = document.getElementById("employeeCount");
            if (el) {
                el.innerText = count;
                el.style.transform = "scale(1.2)";
                el.style.color = "#fff";
                setTimeout(() => { el.style.transform = "scale(1)"; }, 500);
            }
        });

        // 2. Khi duyệt hợp đồng thành công
        connection.on("ContractApproved", (employeeName) => {
            const now = new Date().toLocaleTimeString().substring(0, 8);
            addRow(now, `Nhân viên <b>${employeeName}</b> đã được duyệt hợp đồng và trở thành nhân sự chính thức.`, "✅ Phê duyệt", true);
            showToast(`🎉 Chúc mừng! <b>${employeeName}</b> đã chính thức gia nhập đội ngũ.`, 'success');
        });

        // 3. Nhận tin nhắn/thông báo chung
        connection.on("ReceiveNotification", (data) => {
            if (data.receiver === "HR" || data.receiver === "Tất cả") {
                const content = `<span class="sender-tag">TỪ: ${data.sender}</span> <strong>${data.content}</strong>`;
                addRow(data.time, content, "📩 Tin nhắn đến", true);
                showToast(`📩 Tin nhắn mới từ <b>${data.sender}</b>`, 'info');
            }
        });

        // 4. Các sự kiện cũ của bạn (Chấm công, Nghỉ phép...)
        connection.on("UpdateAttendanceCount", (count, name) => {
            document.getElementById("attendanceCount").innerText = count;
            if (name) addRow(new Date().toLocaleTimeString().substring(0,5), `<b>${name}</b> vừa check-in`, "⏱ Chấm công");
        });

        connection.on("UpdateLeaveCount", (count, name) => {
            document.getElementById("leaveCount").innerText = count;
            if (name) addRow(new Date().toLocaleTimeString().substring(0,5), `<b>${name}</b> vừa gửi đơn nghỉ phép`, "📄 Nghỉ phép", true);
        });

        connection.on("UpdateContractCount", (count, name) => {
            document.getElementById("contractCount").innerText = count;
            if (name) addRow(new Date().toLocaleTimeString().substring(0,5), `<b>${name}</b> yêu cầu ký hợp đồng`, "📑 Hợp đồng", true);
        });

        async function start() {
            try { 
                await connection.start(); 
                document.getElementById("liveStatus").innerText = "● Đang trực tuyến";
                document.getElementById("liveStatus").className = "badge bg-success";
            } catch (err) { setTimeout(start, 5000); }
        }
        start();
    </script>
}