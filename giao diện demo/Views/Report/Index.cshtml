@model IEnumerable<giao_dien_demo.Models.Report>
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Báo cáo tổng hợp Nhân sự";
    var role = Context.Session.GetString("Role");
    
    // Lấy danh sách file báo cáo từ Controller
    var reportFiles = ViewBag.ReportFiles as List<giao_dien_demo.Models.ReportFile> ?? new List<giao_dien_demo.Models.ReportFile>();
}

<div class="container-fluid mt-4 print-container">
    <h2 class="mb-3 d-print-none">📊 Báo cáo tổng hợp Nhân sự</h2>
    
    <div class="d-none d-print-block text-center mb-4">
        <h2 style="text-transform: uppercase; font-weight: bold;">BÁO CÁO TỔNG HỢP NHÂN SỰ</h2>
        <p>Ngày xuất báo cáo: @DateTime.Now.ToString("dd/MM/yyyy")</p>
    </div>
    
    <div class="d-print-none mb-4 d-flex justify-content-between align-items-center">
        <div>
            <a href="javascript:history.back()" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Quay về
            </a>
            <button onclick="window.print()" class="btn btn-primary ms-2">
                <i class="fas fa-print"></i> In Báo Cáo
            </button>
            
            @if (role == "HR")
            {
                <button class="btn btn-success ms-2" data-bs-toggle="modal" data-bs-target="#uploadModal">
                    <i class="fas fa-upload"></i> Upload Báo Cáo Mới
                </button>
            }
        </div>
    </div>

    <div class="card shadow-sm border-0 print-card mb-4" style="border-radius: 12px;">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover mb-0" style="border-radius: 12px; overflow: hidden;">
                <thead class="text-white text-center align-middle print-header" style="background-color: #008080;">
                    <tr>
                        <th>ID</th>
                        <th>Nhân viên</th>
                        <th>Thưởng Lễ</th>
                        <th>Chuyên cần</th>
                        <th>Khen thưởng</th>
                        <th>Kỷ luật</th>
                        <th>Nghỉ phép</th>
                        <th>Nhiệm vụ</th>
                        @if (role == "HR")
                        {
                            <th class="action-col d-print-none">Hành động</th>
                        }
                    </tr>
                </thead>
                <tbody id="reportTableBody" class="text-center align-middle">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="new-row">
                                <td>@item.Id</td>
                                <td class="text-start"><strong>👤 @item.EmployeeName</strong></td>
                                <td class="text-success">@item.HolidayBonus</td>
                                <td class="text-success">@item.DiligenceBonus</td>
                                <td><span class="badge bg-primary print-badge">@item.Reward</span></td>
                                <td><span class="badge bg-danger print-badge">@item.Discipline</span></td>
                                <td>
                                    <span class="badge bg-warning text-dark print-badge">@item.LeaveDays ngày</span><br/>
                                    <small class="text-muted">(@item.LeaveType)</small>
                                </td>
                                <td><span class="badge bg-info text-dark print-badge">@item.TaskStatus</span></td>
                                
                                @if (role == "HR")
                                {
                                    <td class="action-col d-print-none">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i> Sửa
                                        </a>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr id="emptyRow">
                            <td colspan="@(role == "HR" ? "9" : "8")" class="text-center text-muted py-4">
                                <i>Chưa có dữ liệu. Báo cáo sẽ tự động hiển thị khi HR duyệt hợp đồng.</i>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm border-0 d-print-none" style="border-radius: 12px; background-color: #f8f9fa;">
        <div class="card-header bg-white border-bottom-0 pt-3 pb-0">
            <h5 class="fw-bold text-dark"><i class="fas fa-file-pdf text-danger me-2"></i> File Báo cáo đính kèm (Dành cho Ban Lãnh Đạo)</h5>
        </div>
        <div class="card-body">
            @if (reportFiles.Any())
            {
                <table class="table table-hover bg-white rounded shadow-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Tiêu đề</th>
                            <th>Phân loại</th> <th>Tên File</th>
                            <th>Người tải lên</th>
                            <th>Thời gian</th>
                            <th class="text-center">Tải xuống</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var file in reportFiles)
                        {
                            <tr>
                                <td class="fw-bold">@file.Title</td>
                                <td><span class="badge bg-secondary">@file.Category</span></td> <td><i class="fas fa-file-word text-primary me-1"></i> @file.FileName</td>
                                <td>@file.UploadedBy</td>
                                <td>@file.UploadedDate.ToString("HH:mm - dd/MM/yyyy")</td>
                                <td class="text-center">
                                    <a href="/Report/Download?id=@file.Id" class="btn btn-sm btn-info text-white">
                                        <i class="fas fa-download"></i> Tải về
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted mb-0"><i>Chưa có file báo cáo nào được tải lên.</i></p>
            }
        </div>
    </div>
</div>

@if (role == "HR")
{
    <div class="modal fade" id="uploadModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/Report/UploadReport" method="post" enctype="multipart/form-data">
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title"><i class="fas fa-cloud-upload-alt me-2"></i> Tải lên File Báo cáo</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="fw-bold mb-1">Tiêu đề báo cáo</label>
                            <input type="text" name="title" class="form-control" required placeholder="Ví dụ: Báo cáo lương tháng 12">
                        </div>
                        
                        <div class="mb-3">
                            <label class="fw-bold mb-1">Phân loại báo cáo</label>
                            <select name="category" class="form-select" required>
                                <option value="">-- Chọn loại báo cáo --</option>
                                <option value="Báo cáo nhân sự">👥 Báo cáo nhân sự</option>
                                <option value="Báo cáo chấm công">⏱ Báo cáo chấm công</option>
                                <option value="Báo cáo lương">💰 Báo cáo lương</option>
                                <option value="Khác">📌 Khác</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold mb-1">Chọn file đính kèm (.pdf, .doc, .docx)</label>
                            <input type="file" name="fileReport" class="form-control" accept=".pdf,.doc,.docx" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success"><i class="fas fa-paper-plane me-1"></i> Gửi Ban Lãnh Đạo</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<style>
    /* Hiệu ứng nháy sáng cho Web */
    .new-row { animation: highlight 2s ease-out; }
    @@keyframes highlight { from { background-color: #fff9c4; } to { background-color: transparent; } }

    /* --- CẤU HÌNH DÀNH RIÊNG CHO MÁY IN / XUẤT PDF --- */
    @@media print {
        /* 1. Ẩn toàn bộ Menu trái, Topbar của file Layout */
        .sidebar, .topbar, .app-header, .main-sidebar { display: none !important; }

        /* 2. Ép phần nội dung chính tràn viền 100% tờ giấy A4 */
        .app-container, .main-content, .content-area {
            margin: 0 !important; padding: 0 !important; width: 100% !important; max-width: 100% !important; left: 0 !important;
        }

        /* 3. Chỉnh lại Bảng cho sắc nét trên giấy */
        .print-card { border: none !important; box-shadow: none !important; }
        .table { border-collapse: collapse !important; width: 100% !important; }
        .table th, .table td { border: 1px solid #000 !important; padding: 8px !important; color: #000 !important; }

        /* 4. Ép trình duyệt in màu nền của Tiêu đề bảng (Màu xanh teal) */
        .print-header, .print-header th {
            background-color: #008080 !important; color: #ffffff !important;
            -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important;
        }

        /* 5. Gỡ bỏ viền của các nhãn (badge) để nhìn sạch sẽ hơn trên giấy */
        .print-badge {
            border: 1px solid #ccc !important; color: #000 !important; background-color: transparent !important;
            -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important;
        }
    }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Kiểm tra xem có thông báo Thành công / Thất bại từ Controller truyền sang không
        @if (TempData["Success"] != null) {
            <text>
            Swal.fire({ title: 'Thành công!', text: '@TempData["Success"]', icon: 'success', timer: 2000 });
            </text>
        }
        @if (TempData["Error"] != null) {
            <text>
            Swal.fire({ title: 'Lỗi!', text: '@TempData["Error"]', icon: 'error' });
            </text>
        }

        // Bật Real-time
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/dashboardHub")
            .withAutomaticReconnect()
            .build();

        const currentRole = '@role';

        // ⚡ 1. Lắng nghe sự kiện HR duyệt hợp đồng -> Tự động thêm dòng báo cáo (TÍNH NĂNG CŨ)
        connection.on("ContractApproved", function (employeeName) {
            const emptyRow = document.getElementById("emptyRow");
            if (emptyRow) emptyRow.remove();

            const tbody = document.getElementById("reportTableBody");
            const newId = tbody.rows.length + 1;

            let actionColumn = "";
            if (currentRole === "HR") {
                actionColumn = `
                    <td class="action-col d-print-none">
                        <a href="/Report/Edit/${newId}" class="btn btn-sm btn-warning">
                            <i class="fas fa-edit"></i> Sửa
                        </a>
                    </td>`;
            }

            const newRow = `
                <tr class="new-row">
                    <td>${newId}</td>
                    <td class="text-start"><strong>👤 ${employeeName}</strong></td>
                    <td class="text-success">0</td>
                    <td class="text-success">0</td>
                    <td><span class="badge bg-primary print-badge">Chưa có</span></td>
                    <td><span class="badge bg-danger print-badge">Không</span></td>
                    <td>
                        <span class="badge bg-warning text-dark print-badge">0 ngày</span><br/>
                        <small class="text-muted">(---)</small>
                    </td>
                    <td><span class="badge bg-info text-dark print-badge">Mới tiếp nhận</span></td>
                    ${actionColumn}
                </tr>`;
            
            tbody.insertAdjacentHTML("beforeend", newRow);
        });

        // ⚡ 2. Lắng nghe sự kiện Upload File Mới -> Báo cho người đang mở trang biết
        connection.on("NewReportUploaded", function (totalReports) {
            Swal.fire({
                title: 'Có File báo cáo mới!',
                text: 'Hệ thống vừa ghi nhận một file báo cáo mới được tải lên.',
                icon: 'info',
                confirmButtonText: 'Tải lại trang để xem',
                confirmButtonColor: '#17a2b8'
            }).then(() => {
                location.reload();
            });
        });

        // Khởi chạy kết nối
        async function startConnection() {
            try { await connection.start(); console.log("Báo cáo đã kết nối Real-time!"); } 
            catch (err) { setTimeout(startConnection, 5000); }
        }
        startConnection();
    </script>
}