@{
    ViewData["Title"] = "📊 Ban lãnh đạo";
    
    // Lấy dữ liệu đã được Controller tính toán gộp cả hệ thống + file upload
    int empCount = ViewBag.EmpCount ?? 0;
    int attCount = ViewBag.AttCount ?? 0;
    int salCount = ViewBag.SalCount ?? 0;
    
    int doneCount = ViewBag.DoneCount ?? 0;
    int pendingCount = ViewBag.PendingCount ?? 0;

    // Lấy danh sách File đính kèm để in ra bảng dưới biểu đồ
    var reportFiles = ViewBag.ReportFiles as List<giao_dien_demo.Models.ReportFile> ?? new List<giao_dien_demo.Models.ReportFile>();
}

<h2>📊 Báo cáo & Thống kê</h2>

<div class="dashboard-cards" style="margin-top:30px;">
    <div class="card blue" style="cursor: default; pointer-events: none;">
        👥 Báo cáo nhân sự
        <div class="number" id="leaderEmpCount">@empCount</div>
    </div>

    <div class="card green" style="cursor: default; pointer-events: none;">
        ⏱ Lượt chấm công
        <div class="number" id="leaderAttCount">@attCount</div>
    </div>

    <div class="card red" style="cursor: default; pointer-events: none;">
        💰 Báo cáo lương
        <div class="number" id="leaderSalCount">@salCount</div>
    </div>

    <div class="card purple" style="cursor: default; pointer-events: none;">
        🔄 Cập nhật dữ liệu
        <div class="number" style="font-size: 26px; padding-top: 8px;">Real-time</div>
    </div>
</div>

<div style="margin-top:40px; display:flex; gap:30px; flex-wrap:wrap;">
    <div style="flex:1; min-width:400px;">
        <h4>📊 Số lượng báo cáo</h4>
        <canvas id="barChart"></canvas>
    </div>

    <div style="flex:1; min-width:400px;">
        <h4>🥧 Trạng thái báo cáo</h4>
        <canvas id="pieChart"></canvas>
    </div>
</div>

<div style="margin-top:40px;">
    <h3>📋 Tổng quan báo cáo</h3>

    <table class="table table-bordered table-hover">
        <thead class="table-primary">
            <tr>
                <th>Loại báo cáo</th>
                <th>Trạng thái</th>
                <th>Số lượng</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Báo cáo nhân sự</td>
                <td>Hoàn tất</td>
                <td id="tableEmpCount">@empCount</td>
            </tr>
            <tr>
                <td>Báo cáo lương</td>
                <td>Đang xử lý</td>
                <td id="tableSalCount">@salCount</td>
            </tr>
            <tr>
                <td>Báo cáo chấm công</td>
                <td>Hoàn tất</td>
                <td id="tableAttCount">@attCount</td>
            </tr>
        </tbody>
    </table>
</div>

<div class="card shadow-sm border-0 mt-5" style="border-radius: 12px; background-color: #f8f9fa;">
    <div class="card-header bg-white border-bottom-0 pt-3 pb-0">
        <h5 class="fw-bold text-dark"><i class="fas fa-file-pdf text-danger me-2"></i> Báo cáo đính kèm từ HR</h5>
    </div>
    <div class="card-body">
        @if (reportFiles.Any())
        {
            <table class="table table-hover bg-white rounded shadow-sm">
                <thead class="table-light">
                    <tr>
                        <th>Tiêu đề</th>
                        <th>Phân loại</th>
                        <th>Tên File</th>
                        <th>Người tải lên</th>
                        <th>Thời gian</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in reportFiles)
                    {
                        <tr>
                            <td class="fw-bold">@file.Title</td>
                            <td><span class="badge bg-secondary">@file.Category</span></td>
                            <td><i class="fas fa-file-word text-primary me-1"></i> @file.FileName</td>
                            <td>@file.UploadedBy</td>
                            <td>@file.UploadedDate.ToString("HH:mm - dd/MM/yyyy")</td>
                            <td class="text-center">
                                <a href="/Report/Download?id=@file.Id" class="btn btn-sm btn-info text-white">
                                    <i class="fas fa-download"></i> Tải nội dung
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted mb-0"><i>Chưa có file báo cáo nào được gửi từ HR.</i></p>
        }
    </div>
</div>

<div style="margin-top:30px; margin-bottom: 50px;">
    <button class="btn btn-success" onclick="window.print()">
        <i class="fas fa-file-pdf"></i> 📥 Xuất báo cáo màn hình (PDF)
    </button>
    <a href="/Report/Index" class="btn btn-outline-primary ms-2">
        <i class="fas fa-list"></i> Xem bảng KPI nhân viên chi tiết
    </a>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // DỮ LIỆU TỪ BACKEND
        let currentEmp = @empCount;
        let currentAtt = @attCount;
        let currentSal = @salCount;
        let currentDone = @doneCount;
        let currentPending = @pendingCount;

        // VẼ BIỂU ĐỒ CỘT
        const myBarChart = new Chart(document.getElementById('barChart'), {
        type: 'bar',
        data: {
        labels: ['Nhân sự', 'Chấm công', 'Lương'],
        datasets: [{
        label: 'Số lượng',
        data: [currentEmp, currentAtt, currentSal],
        backgroundColor: ['#36A2EB', '#4BC0C0', '#FF6384']
        }]
        },
        options: { scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
        });

        // VẼ BIỂU ĐỒ TRÒN
        const myPieChart = new Chart(document.getElementById('pieChart'), {
        type: 'pie',
        data: {
        labels: ['Hoàn tất', 'Đang xử lý'],
        datasets: [{
        data: [currentDone, currentPending],
        backgroundColor: ['#4BC0C0', '#FF6384']
        }]
        }
        });

        // KẾT NỐI SIGNALR
        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/dashboardHub")
        .withAutomaticReconnect()
        .build();

        // Lắng nghe Duyệt hợp đồng
        connection.on("UpdateEmployeeCount", function (newEmpCount) {
        window.location.reload();
        });

        // Lắng nghe Chấm công
        connection.on("UpdateAttendanceCount", function (totalCount, userName) {
        window.location.reload();
        });

        // 🔥 LẮNG NGHE UPLOAD FILE: Tự động tải lại để nhận diện Category mới
        connection.on("NewReportUploaded", function (totalReports, reportTitle) {
        Swal.fire({
        title: 'Có File báo cáo mới!',
        text: 'HR vừa tải lên: ' + reportTitle,
        icon: 'info',
        confirmButtonColor: '#3085d6',
        confirmButtonText: 'Cập nhật số liệu ngay'
        }).then(() => {
        window.location.reload(); // Load lại để Controller tính toán lại Category
        });
        });

        async function startConnection() {
        try {
        await connection.start();
        console.log("Dashboard Leader đã kết nối Real-time!");
        } catch (err) {
        setTimeout(startConnection, 5000);
        }
        }
        
        startConnection();
    </script>
}