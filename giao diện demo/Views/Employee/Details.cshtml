@model giao_dien_demo.Models.Employee

@{
    ViewData["Title"] = "Hồ sơ chi tiết nhân viên";
}

<style>
    /* Style cho Profile Card chuyên nghiệp */
    .profile-card { border-radius: 15px; overflow: hidden; border: none; transition: 0.3s; }
    .profile-header { 
        background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); 
        color: white; 
        padding: 40px 20px; 
        text-align: center; 
    }
    .avatar-wrapper {
        width: 120px;
        height: 120px;
        background: white;
        border-radius: 50%;
        margin: 0 auto 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 50px;
        border: 4px solid rgba(255,255,255,0.2);
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        overflow: hidden;
    }
    .avatar-wrapper img { width: 100%; height: 100%; object-fit: cover; }
    
    .info-label { color: #64748b; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .info-value { color: #1e293b; font-weight: 600; margin-bottom: 1.5rem; font-size: 1rem; }
    .section-title { 
        border-left: 4px solid #3b82f6; 
        padding-left: 10px; 
        margin-bottom: 20px; 
        font-weight: 700; 
        color: #1e3a8a;
    }
</style>

<div class="container mt-4 mb-5">
    <div class="card profile-card shadow-lg mx-auto" style="max-width: 900px;">
        <div class="profile-header">
            <div class="avatar-wrapper">
                @if (!string.IsNullOrEmpty(Model.AvatarPath))
                {
                    <img src="@Model.AvatarPath" alt="Avatar" />
                }
                else
                {
                    <span>👤</span>
                }
            </div>
            <h2 class="fw-bold mb-1">@Model.Name</h2>
            <div class="badge bg-light text-primary px-3 py-2 fs-6">@Model.JobTitle</div>
            <p class="mt-2 opacity-75">Mã nhân viên: <span class="fw-bold">@Model.EmployeeCode</span></p>
        </div>

        <div class="card-body p-4 p-md-5">
            <div class="row">
                <div class="col-md-6 border-end">
                    <h5 class="section-title">📌 Thông tin cá nhân</h5>
                    
                    <div class="info-label">Số điện thoại</div>
                    <div class="info-value">@(Model.PhoneNumber ?? "Chưa cập nhật")</div>

                    <div class="info-label">Email liên hệ</div>
                    <div class="info-value">@(Model.Email ?? "Chưa có email")</div>

                    <div class="info-label">Giới tính / Ngày sinh</div>
                    <div class="info-value">
                        @(Model.Gender ?? "N/A") | @(Model.BirthDate?.ToString("dd/MM/yyyy") ?? "N/A")
                    </div>

                    <div class="info-label">Số CCCD</div>
                    <div class="info-value">@(Model.CitizenId ?? "Chưa cập nhật")</div>

                    <div class="info-label">Địa chỉ thường trú</div>
                    <div class="info-value">@(Model.Address ?? "Chưa cập nhật")</div>
                </div>

                <div class="col-md-6 ps-md-4">
                    <h5 class="section-title">💼 Công việc & Tài chính</h5>

                    <div class="info-label">Phòng ban</div>
                    <div class="info-value">@Model.Department</div>

                    <div class="info-label">Loại hợp đồng</div>
                    <div class="info-value">@Model.Position</div>

                    <div class="info-label">Mức lương cơ bản</div>
                    <div class="info-value text-success">@Model.Salary.ToString("N0") VNĐ</div>

                    <div class="info-label">Tài khoản ngân hàng</div>
                    <div class="info-value">
                        @if (!string.IsNullOrEmpty(Model.BankName))
                        {
                            <span>@Model.BankName - @Model.BankAccountNumber</span>
                        }
                        else
                        {
                            <span class="text-muted italic">Chưa cập nhật</span>
                        }
                    </div>
                </div>
            </div>

            <div class="mt-4 pt-4 border-top d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 me-2">
                        <i class="bi bi-pencil-square"></i> Sửa hồ sơ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>